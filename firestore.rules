rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uidField) {
      return isSignedIn() && request.auth.uid == uidField;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /storico_atleti/{docId} {
      allow create: if isSignedIn() && request.resource.data.atletaId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.atletaId == request.auth.uid;
    }

    match /schede_assegnate/{docId} {
      allow read: if isSignedIn() && resource.data.atletaId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
